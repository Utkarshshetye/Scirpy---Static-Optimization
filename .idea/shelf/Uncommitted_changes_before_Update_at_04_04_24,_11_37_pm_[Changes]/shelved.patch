+import matplotlib.pyplot as plt
+file_path = '/home/chiranmoy/IdeaProjects/data/fbi_reports.csv'
+SO_columns = ["Perpetrator Count","Victim Count","Victim Age","City","Weapon"]
+SO_c_d_t = {}
+fbi_data = pd.read_csv(file_path,usecols=SO_columns,dtype=SO_c_d_t)
+fbi_data.info()
+print(fbi_data.head())
+plt.title('Incidents by Year')
+plt.xlabel('Year')
+plt.ylabel('Number of Incidents')
+incidents_by_year = fbi_data.groupby('Year').count()
+plt.plot(incidents_by_year.compute(live_df=[fbi_data]))
+plt.xticks(rotation=20)
+plt.savefig('fig1.png')
+plt.close()
+plt.title('Top 10 Weapons Used')
+weapons_distribution = fbi_data['Weapon'].value_counts().head(10)
+weapons_labels = weapons_distribution.index
+plt.pie(weapons_distribution.compute(live_df=[fbi_data, weapons_labels]),labels=weapons_labels.compute(live_df=[fbi_data]),explode=((([0] * 3) + ([0.25] * 3)) + ([0.75] * 4)),autopct='%1.1f%%')
+plt.savefig('fig2.png')
+plt.close()
+plt.title('Top 10 Most Dangerous Cities')
+plt.xlabel('City')
+plt.ylabel('Number of Incidents')
+dangerous_cities = fbi_data['City'].value_counts().head(10)
+cities_label = dangerous_cities.index
+plt.bar(x=cities_label.compute(live_df=[fbi_data, dangerous_cities]),height=dangerous_cities.compute(live_df=[fbi_data]))
+plt.xticks(rotation=20)
+plt.savefig('fig3.png')
+plt.close()
+average_victim_age_by_race = fbi_data.groupby('Victim Race')['Victim Age'].mean()
+print('Average Victim Age by Race:')
+print(average_victim_age_by_race)
+total_victims = fbi_data['Victim Count'].sum()
+total_perpetrators = fbi_data['Perpetrator Count'].sum()
+print(f'Total Number of Victims: {total_victims}')
+print(f'Total Number of Perpetrators: {total_perpetrators}')
