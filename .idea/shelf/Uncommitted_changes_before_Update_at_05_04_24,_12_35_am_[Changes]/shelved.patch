ory Information\n                        line = br.readLine();//category\n                        sc = new Scanner(line);\n                        sc.useDelimiter(\",\");\n                        boolean[] isCategory=new boolean[metaData.getClmnList().size()];\n                        j=0;\n                        while(sc.hasNext()) {\n                            isCategory[j]=sc.nextBoolean();\n                            j++;\n                        }\n                        metaData.setIsCategory(isCategory);\n                        exists = true;\n                        break;\n                    }\n                }\n            }\n            br.close();\n            fr.close();\n        }\n        catch (IOException e){\n            System.out.println(\"Meta data IO Error:\"+e.getMessage());\n        }\n        if(!exists) {\n            return null;\n        }\n            return metaData;\n    }\n}\n
